// PROPUESTA DE NUEVA TABLA PARA HISTORIAL DE HORARIOS
// Este archivo documenta la nueva tabla que se debe agregar al schema principal

model HorarioHistorial {
  id                Int       @id @default(autoincrement()) @map("PK_id_horario_historial")
  empleadoId        Int       @map("FK_id_empleado")
  weekStartDate     DateTime  @map("week_start_date") @db.Date
  versionNumber     Int       @map("version_number") @default(1)
  changeReason      String?   @map("change_reason") @db.VarChar(500)
  changedBy         Int?      @map("changed_by") // ID del usuario que hizo el cambio
  createdAt         DateTime  @default(now()) @map("created_at")
  
  // Snapshot de los horarios en formato JSON
  scheduleSnapshot  String    @map("schedule_snapshot") @db.Text
  
  // Relaciones
  empleado          Empleado  @relation(fields: [empleadoId], references: [id], onUpdate: NoAction)
  usuario           Usuario?  @relation(fields: [changedBy], references: [id], onUpdate: NoAction)
  
  @@unique([empleadoId, weekStartDate, versionNumber])
  @@index([empleadoId, weekStartDate])
  @@index([createdAt])
  @@map("Horario_Historial")
}

